// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  RESTAURANT_ADMIN
  DRIVER
  CUSTOMER
}

enum TenantType {
  MARKETPLACE
  WHITE_LABEL
}

enum OrderStatus {
  CREATED
  PENDING
  SEARCHING_DRIVER
  OFFERED_TO_DRIVER
  CONFIRMED
  PREPARING
  READY
  ASSIGNED
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum TransactionType {
  COMMISSION
  SUBSCRIPTION_PAYMENT
  ADJUSTMENT
}

model Tenant{
  idTenant String @id @default(uuid())
  name String
  type TenantType

  idSubscriptionPlan String
  subscriptionPlan SubscriptionPlan @relation(fields: [idSubscriptionPlan],references: [idSubscriptionPlan])

  commissionRate Float
  allowOwnDrivers Boolean @default(false)
  isActive Boolean @default(true)

  users User[]
  restaurants Restaurant[]
  orders Order[]
  tenantTransactions TenantTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  idSubscriptionPlan String @id @default(uuid())
  name String
  monthlyPrice Float
  commissionRate Float
  allowWhiteLabel Boolean
  allowOwnDrivers Boolean
  dispatchPriority Int @default(0)

  tenants Tenant[]
}

model TenantTransaction {
  idTenantTransaction String @id @default(uuid())

  idTenant String
  tenant Tenant @relation(fields: [idTenant],references: [idTenant])

  idOrder String?
  amount Float
  type TransactionType

  createdAt DateTime @default(now())

  @@index([idTenant])
}

model User {
  idUser  String @id @default(uuid())
  name String
  surname String
  ci  String @unique
  email String @unique
  password String
  role Role @default(CUSTOMER)
  isActive Boolean @default(true)
  isOnline Boolean @default(false)
  isAvailable Boolean @default(true)
  isShared Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tokens RefreshToken[]

  restaurant Restaurant? @relation("RestaurantOwner",fields: [idRestaurant],references: [idRestaurant])
  idRestaurant String?
  
  customerOrders Order[] @relation("CustomerOrders")
  driverOrders Order[] @relation("DriverOrders")

  idTenant String
  tenant Tenant @relation(fields: [idTenant],references: [idTenant])

  drivers DriverLocation[]

  @@index([idTenant,isOnline,isAvailable])
}

model RefreshToken {
  idRefreshToken String @id @default(uuid())
  token String
  idUser String
  user User @relation(fields: [idUser],references: [idUser],onDelete: Cascade)
  
  deviceId String
  userAgent String?
  ipAddress String?
  
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked Boolean @default(false)
}

model Restaurant {
  idRestaurant String @id @default(uuid())
  name String
  address String
  lat Float
  lng Float
  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  users User[] @relation("RestaurantOwner") 
  products Product[]
  orders Order[]

  idTenant String
  tenant Tenant @relation(fields: [idTenant],references: [idTenant])
}

model Product {
  idProduct String @id @default(uuid())
  name String
  price Float

  restaurant Restaurant @relation(fields: [idRestaurant],references: [idRestaurant])
  idRestaurant String

  orderItem OrderItem []
}

model Order {
  idOrder String @id @default(uuid())
  orderNumber Int @default(autoincrement())

  customerLat Float?
  customerLng Float?
  customer User @relation("CustomerOrders",fields: [idCustomer], references: [idUser])
  idCustomer String

  restaurant Restaurant @relation(fields: [idRestaurant],references: [idRestaurant])
  idRestaurant String

  driver User? @relation("DriverOrders",fields: [idDriver],references: [idUser])
  idDriver String?

  idTenant String
  tenant Tenant @relation(fields: [idTenant],references: [idTenant])
  
  status OrderStatus @default(CREATED)

  pickupLat Float
  pickupLng Float
  
  commissionAmount Float?
  driverEarning Float?
  platformEarning Float?

  subtotal Float
  discount Float?
  total Float

  deliveryAddress String
  deliveryLat Float
  deliveryLng Float
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offerExpiresAt DateTime?
  offeredDriverId String?


  orderItem OrderItem []

  @@index([idTenant])
  @@index([idRestaurant])
  @@index([idDriver])
}

model OrderItem {
  idOrderItem String @id @default(uuid())
  idOrder String
  idProduct String
  quantity Int
  priceAtPurchase Float

  order Order @relation(fields: [idOrder],references: [idOrder])
  product Product @relation(fields: [idProduct],references: [idProduct])
}

model DriverLocation {
  idDriverLocation String @id @default(uuid())
  idDriver String @unique
  driver User @relation(fields: [idDriver],references: [idUser])

  lat Float
  lng Float
  isOnline Boolean @default(true)

  location Unsupported("geometry(Point,4326)")

  updatedAt DateTime @updatedAt

  @@index([lat,lng])
}
